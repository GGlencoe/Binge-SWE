# ──────────────────────────────────────────────
# Binge Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# Supabase project URL (found in Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — safe to expose in frontend, used here for token validation
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — KEEP SECRET, grants full DB access, backend-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# URL of the Next.js frontend (for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# Port the Express server listens on
PORT=4000

# ──────────────────────────────────────────────
# External API Keys (add as you integrate)
# ──────────────────────────────────────────────

# YELP_API_KEY=
# GOOGLE_PLACES_API_KEY=
# SPOONACULAR_API_KEY=
# OPENAI_API_KEY=
